{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vellum",
  "version": "0.1.0",
  "identifier": "com.wimi.vellum",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vellum",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:*; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
